  geom_hline(yintercept = 0, linetype = "dashed", alpha = 0.5) + # Zero induced vertical break
  geom_point(alpha = 0.6, size = 2) +
  facet_wrap(~player) + # Separate plots for each player
  scale_color_brewer(palette = "Set1") + # A good palette for distinct pitch types
