# 7. Comparative Movement Profile: Induced Vertical Break (IVB) vs Horizontal Break (HB)
# This is the "Stuff" analysis. MLB teams look for "Vertical Separation" and unique movement.
message("Generating Movement Profile Plots...")

process_movement <- function(data, player_label) {
  data %>%
    filter(!is.na(pfx_x), !is.na(pfx_z)) %>%
    mutate(
      # Convert Statcast feet to inches
      # pfx_x is catcher's perspective: positive is move toward RHH
      HB = pfx_x * -12, 
      IVB = pfx_z * 12,
      player = player_label
    )
}

roupp_movement <- process_movement(roupp_raw, "Roupp (2026)")
nola_movement <- process_movement(nola_raw, "Nola (2018)")

combined_movement <- bind_rows(roupp_movement, nola_movement)

