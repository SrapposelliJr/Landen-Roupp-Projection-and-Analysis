# 10. Pitch Arsenal Similarity Analysis
message("Calculating Pitch Arsenal Similarity...")

get_pitch_traits <- function(data, label) {
  total_pitches <- nrow(data)
  data %>%
    filter(!is.na(pitch_name), !is.na(description)) %>%
    group_by(pitch_name) %>%
    summarize(
      player = label,
      Velo = mean(release_speed, na.rm = TRUE),
      IVB = mean(pfx_z, na.rm = TRUE) * 12,
      HB = mean(pfx_x, na.rm = TRUE) * -12,
      Usage = (n() / total_pitches) * 100,
      # Calculate Whiff%
      swings = sum(description %in% c("swinging_strike", "swinging_strike_blocked", "foul", "foul_tip", "hit_into_play", "missed_bunt", "foul_bunt"), na.rm = TRUE),
      whiffs = sum(description %in% c("swinging_strike", "swinging_strike_blocked", "missed_bunt"), na.rm = TRUE),
      Whiff_Pct = (whiffs / max(1, swings)) * 100
    ) %>%
    filter(Usage > 2) %>%
    select(player, pitch_name, Velo, IVB, HB, Usage, Whiff_Pct)
}

# Extract traits
roupp_traits <- get_pitch_traits(roupp_raw, "Roupp")
nola_traits <- get_pitch_traits(nola_raw, "Nola")

# Standardize pitch names for comparison (e.g., Curveball vs Knuckle Curve)
roupp_traits <- roupp_traits %>% 
  mutate(pitch_compare = ifelse(pitch_name == "Curveball", "Breaking Ball", pitch_name))

nola_traits <- nola_traits %>% 
  mutate(pitch_compare = ifelse(pitch_name == "Knuckle Curve", "Breaking Ball", pitch_name))

# Join datasets on mapped pitch types
comparison_table <- inner_join(
  roupp_traits, 
  nola_traits, 
  by = "pitch_compare", 
  suffix = c("_Roupp", "_Nola")
)

# Calculate Similarity Score per pitch type
similarity_results <- comparison_table %>%
  mutate(
    diff_usage = abs(Usage_Roupp - Usage_Nola),
    diff_velo = abs(Velo_Roupp - Velo_Nola),
    diff_hb = abs(HB_Roupp - HB_Nola),
    diff_ivb = abs(IVB_Roupp - IVB_Nola),
    diff_whiff = abs(Whiff_Pct_Roupp - Whiff_Pct_Nola),
    avg_diff = (diff_usage + diff_velo + diff_hb + diff_ivb + diff_whiff) / 5,
    similarity = 100 - avg_diff
  )

# Print results
print("Pitch-by-Pitch Trait Comparison:")
print(similarity_results %>% select(pitch_compare, similarity, avg_diff))

final_score <- mean(similarity_results$similarity)
cat("\n--- FINAL ARSENAL SIMILARITY SCORE ---\n")
cat("Roupp (2026) vs Nola (2018): ", round(final_score, 2), "%\n")

