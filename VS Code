# 12. FIP- Projection Curve (Next 4 Seasons)
message("Projecting FIP- Curve...")

# Calculate baseline 2026 stats
roupp_2026_stats <- roupp_raw %>%
  summarize(
    k = sum(events == "strikeout", na.rm = TRUE),
    bb = sum(events == "walk", na.rm = TRUE),
    hbp = sum(events == "hit_by_pitch", na.rm = TRUE),
    hr = sum(events == "home_run", na.rm = TRUE),
    # Estimate innings pitched based on outs recorded
    outs = sum(events %in% c("field_out", "strikeout", "strikeout_double_play", "foul_out", 
                            "force_out", "grounded_into_double_play", "fielders_choice_out"), na.rm = TRUE),
    ip = outs / 3
  ) %>%
  mutate(
    # Using standard 2026 FIP constant (~3.15) and League Avg FIP (~4.20)
    fip = ((13 * hr + 3 * (bb + hbp) - 2 * k) / ip) + 3.15,
    fip_minus = (fip / 4.20) * 100
  )

baseline_fip_minus <- roupp_2026_stats$fip_minus

# Create projection data based on standard aging curves (Peak at 27-28, slow decline after 29)
projections <- tibble(
  season = c(2026, 2027, 2028, 2029, 2030),
  age = c(27, 28, 29, 30, 31),
  # Multipliers: 2027 (Peak -2%), 2028 (Flat), 2029 (+3% decline), 2030 (+5% decline)
  proj_fip_minus = baseline_fip_minus * c(1.0, 0.98, 1.0, 1.03, 1.08),
  type = c("Actual", "Projected", "Projected", "Projected", "Projected")
)

fip_minus_plot <- ggplot(projections, aes(x = season, y = proj_fip_minus, group = 1)) +
  geom_line(linewidth = 1.2, color = "#FD5A1E") +
  geom_point(aes(color = type), size = 4) +
  # Add league average line
  geom_hline(yintercept = 100, linetype = "dashed", color = "black", alpha = 0.5) +
  annotate("text", x = 2026, y = 102, label = "League Average (100)", size = 3, hjust = 0) +
  scale_color_manual(values = c("Actual" = "#000000", "Projected" = "#FD5A1E")) +
  labs(
    title = "Landen Roupp FIP- Projection Curve",
    subtitle = "Projected Performance relative to League Average (Lower is Better)",
    x = "Season",
    y = "FIP- (League Normalized)",
    caption = "Baseline: 2026 Statcast Data | Projections: Standard Pitcher Aging Profile",
    color = "Data Status"
  ) +
  theme_minimal() +
  theme(legend.position = "bottom") +
  # Flip Y axis because lower FIP- is better
  scale_y_reverse(breaks = seq(60, 120, 10))

print(fip_minus_plot)

