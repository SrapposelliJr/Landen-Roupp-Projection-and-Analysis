# 2. Function to calculate whiff rates for all pitch types
get_arsenal_whiffs <- function(data, label) {
  data %>%
    filter(!is.na(pitch_name), !is.na(description)) %>%
    group_by(pitch_name) %>%
    summarize(
      player = label,
      swings = sum(description %in% c("swinging_strike", "swinging_strike_blocked", "foul", "foul_tip", "hit_into_play", "missed_bunt", "foul_bunt"), na.rm = TRUE),
      whiffs = sum(description %in% c("swinging_strike", "swinging_strike_blocked", "missed_bunt"), na.rm = TRUE),
      whiff_rate = (whiffs / max(1, swings)) * 100
    ) %>%
    filter(swings > 5) # Filter out pitches with a low sample size
}

# 3. Process the data
